DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

TEXT_BASE_URL=https://api.deepseek.com
TEXT_MODEL=deepseek-v4-flash
TEXT_ENABLE_WEB_SEARCH=false

# VLM for click understanding. qwen-vl-plus is faster; qwen-vl-max-latest is more accurate.
VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_MODEL=qwen-vl-plus

# Image provider: "dashscope" (async-poll wanx, ~20-60 s) or "siliconflow" (sync Flux, ~3-8 s)
IMAGE_PROVIDER=dashscope

# --- DashScope image models (used when IMAGE_PROVIDER=dashscope) ---
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
IMAGE_TIER=balanced
DASHSCOPE_IMAGE_MODEL_FAST=wanx2.1-t2i-turbo
DASHSCOPE_IMAGE_MODEL_BALANCED=wanx2.1-t2i-plus
DASHSCOPE_IMAGE_MODEL_PRO=wanx2.1-t2i-max

# --- SiliconFlow image models (used when IMAGE_PROVIDER=siliconflow) ---
# Get a free API key at https://siliconflow.cn
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_IMAGE_MODEL_FAST=black-forest-labs/FLUX.1-schnell
SILICONFLOW_IMAGE_MODEL_BALANCED=black-forest-labs/FLUX.1-dev
SILICONFLOW_IMAGE_MODEL_PRO=black-forest-labs/FLUX.1-pro

VIDEO_TIER=fast
DASHSCOPE_VIDEO_MODEL_FAST=wanx2.1-i2v-turbo
DASHSCOPE_VIDEO_MODEL_BALANCED=wanx2.1-i2v-plus
DASHSCOPE_VIDEO_MODEL_PRO=wanx2.1-i2v-max
ANIMATE_PROMPT_REWRITE=true

CORS_ORIGINS=http://localhost:3000
